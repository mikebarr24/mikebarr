{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mike Barr blog posts",
  "description": "Schema for data/blog-posts.json. Published posts become static pages during the Next.js export.",
  "type": "array",
  "items": {
    "oneOf": [
      {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slug",
          "status",
          "title",
          "summary",
          "publishedAt",
          "readingTimeMinutes",
          "tags",
          "content"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "URL-safe slug used for the static route, for example /blog/my-post/."
          },
          "status": {
            "const": "published"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "publishedAt": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
            "description": "Publication date in YYYY-MM-DD format."
          },
          "updatedAt": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "readingTimeMinutes": {
            "type": "integer",
            "minimum": 1
          },
          "featured": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "content": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/contentBlock"
            }
          }
        }
      },
      {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slug",
          "status",
          "title",
          "summary",
          "readingTimeMinutes",
          "tags",
          "content"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "status": {
            "const": "draft"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "updatedAt": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "readingTimeMinutes": {
            "type": "integer",
            "minimum": 1
          },
          "featured": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "content": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/contentBlock"
            }
          }
        }
      }
    ]
  },
  "$defs": {
    "contentBlock": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "text"],
          "properties": {
            "type": {
              "const": "paragraph"
            },
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "text"],
          "properties": {
            "type": {
              "const": "heading"
            },
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "items"],
          "properties": {
            "type": {
              "const": "list"
            },
            "items": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    }
  }
}
